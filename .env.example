# Copy to `.env.local` (gitignored) for `npm run dev`. Use the SAME values conceptually as Amplify build env.

# Required: Lambda Function URL origin only — no path, no trailing slash
# Example: https://abc123xyz.lambda-url.us-east-1.on.aws
VITE_ADMIN_AUTH_URL=

# Optional: override public CMS JSON URL (default is the S3 object in src/content/siteContent.ts)
# VITE_SITE_CONTENT_URL=

# Optional: override vendors roster JSON (default is vendors.json on the same CMS bucket pattern)
# VITE_VENDORS_URL=
